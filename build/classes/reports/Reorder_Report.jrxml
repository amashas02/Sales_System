	<queryString>
		<![CDATA[SELECT 
    p.product_name, 
    p.available_qty, 
    s.supplier_name, 
    s.tp_number, 
    s.address
FROM products p
INNER JOIN supplier s ON p.sid = s.sid
WHERE p.available_qty <= 10
ORDER BY p.available_qty ASC;]]>
	</queryString>
