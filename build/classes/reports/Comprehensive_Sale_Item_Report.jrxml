	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="CoffeeShopLink"/>
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<parameter name="sid" class="java.lang.Integer"/>
	<queryString>
		<![CDATA[SELECT 
    s.sale_id AS 'Invoice ID',
    p.product_name AS 'Product Name',
    sd.qty AS 'Quantity',
    sd.price AS 'Unit Price',
    sd.total_price AS 'Subtotal',
    s.total_bill AS 'Grand Total',
    s.pay_amount AS 'Paid',
    s.balance AS 'Balance'
FROM sales s
INNER JOIN sales_details sd ON s.sale_id = sd.sale_id
INNER JOIN products p ON sd.product_id = p.product_id
WHERE s.sale_id = $P{sid}]]>
	</queryString>
