	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="CoffeeShopLink"/>
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<queryString>
		<![CDATA[SELECT 
    p.product_name AS 'Product Name',
    SUM(sd.qty) AS 'Total Sold',
    s.supplier_name AS 'Supplier Name',
    s.tp_number AS 'Contact Number'
FROM sales_details sd
INNER JOIN products p ON sd.product_id = p.product_id
INNER JOIN supplier s ON p.sid = s.sid
GROUP BY sd.product_id
ORDER BY SUM(sd.qty) DESC;]]>
	</queryString>
