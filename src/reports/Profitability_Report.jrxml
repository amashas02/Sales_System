<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Profitability_Report" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="7c6be52a-3c02-4c52-961d-a3521c5624d6">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="CoffeeShopLink"/>
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<queryString>
		<![CDATA[SELECT 
    p.product_name, 
    SUM(sd.qty) AS total_quantity_sold, 
    SUM(sd.total_price) AS total_revenue,
    SUM(sd.qty * p.buy_price) AS total_cost,
    SUM(sd.total_price - (sd.qty * p.buy_price)) AS net_profit
FROM sales_details sd
INNER JOIN products p ON sd.product_id = p.product_id
GROUP BY p.product_id
ORDER BY net_profit DESC;]]>
	</queryString>
